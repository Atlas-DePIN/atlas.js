{
  "name": "atlas.js",
  "version": "0.1.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.esm.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.esm.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs.js"
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "test": "echo \"Error: no test specified\" && exit 1",
    "docs:typedoc": "typedoc",
    "docs:website:gen": "npx typedoc --options website/typedoc.json && find website/docs/api -name '*.md' -exec sed -i 's/{EventEmitter}/`EventEmitter`/g; s/{EventTarget}/`EventTarget`/g' {} +",
    "docs:website:dev": "pnpm docs:website:gen && cd website && pnpm start",
    "docs:website:build": "pnpm docs:website:gen && cd website && pnpm build",
    "docs:website:serve": "cd website && pnpm serve"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^22.9.0",
    "rollup-plugin-typescript-paths": "^1.5.0",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.0.4",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.0.3",
    "vite-plugin-node-polyfills": "^0.23.0",
    "vite-tsconfig-paths": "^4.2.1"
  },
  "dependencies": {
    "@atlas/atlas.js-protos": "file:atlas-atlas.js-protos-0.1.3.tgz",
    "@cosmjs/encoding": "^0.38.1",
    "@cosmjs/proto-signing": "^0.38.1",
    "@cosmjs/stargate": "^0.38.1",
    "@cosmjs/tendermint-rpc": "^0.38.1",
    "@cosmology/lcd": "^0.15.0",
    "@noble/hashes": "^1.8.0",
    "@openzeppelin/merkle-tree": "^1.0.8",
    "axios": "^1.13.3",
    "cosmjs-types": "^0.11.0",
    "eciesjs": "^0.5.0",
    "hash-wasm": "^4.12.0",
    "merkletreejs": "^0.6.0",
    "treeify": "^1.1.0",
    "xxh3-ts": "^2.0.1"
  }
}
