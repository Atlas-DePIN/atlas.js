{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,

    // "stripInternal": true,

    /* Bundler mode */
    "sourceMap": false,
    "declaration": true,
    "resolveJsonModule": true,
    // "isolatedModules": true,
    // "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "types": ["node"],

    /* Linting */
    "strict": false,

    "outDir": "dist",
    "rootDir": "./src",
    
    "typeRoots": [
      "node_modules/@types",
      "./src/interfaces",
      "src/interfaces"
    ]
  },
  "include": [
    "src/**/*.ts",
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests/**/*.ts"
  ]
}